---
layout: layout.liquid
title: Dhruvang Gajjar
description: Dhruvang, a software engineer with 6+ YoE in web development industry. Product Management, Problem solving and requiement understanding expert.
eleventyExcludeFromCollections: true
---
<section class="text-gray-600 body-font">
    <div class="container mx-auto flex px-5 py-8 md:py-24 md:flex-row flex-col items-center">
        <div
            class="lg:flex-grow md:w-1/2 lg:pl-24 md:pl-16 flex flex-col md:items-start md:text-left items-center text-center">
            <h1 class="title-font sm:text-4xl text-3xl mb-4 font-medium text-gray-900">From Algorithms to Applications:
                <br class="hidden lg:inline-block">Your Guide to Software Mastery
            </h1>
            <p class="mb-8 leading-relaxed">Embark on a transformative journey as we delve into the intricate world of
                algorithms, unveiling the secrets that bridge theory to real-world applications. Your ultimate guide to
                mastering software awaits.</p>
            <div class="flex justify-center">
                <a href="/blog"
                    class="inline-flex text-white bg-gray-500 border-0 py-2 px-6 focus:outline-none hover:bg-gray-600 rounded text-lg">Explore
                    Blogs</a>
                <!-- <button
                    class="ml-4 inline-flex text-gray-700 bg-gray-100 border-0 py-2 px-6 focus:outline-none hover:bg-gray-200 rounded text-lg">Button</button> -->
            </div>
        </div>
    </div>
</section>

<section class="text-gray-600 body-font">
    <div class="container px-5 py-8 md:py-24 mx-auto">
        <div class="flex flex-wrap w-full mb-20">
            <div class="lg:w-1/2 w-full mb-6 lg:mb-0">
                <h2 class="sm:text-3xl text-2xl font-medium title-font mb-2 text-gray-900">Featured Articles</h2>
                <div class="h-1 w-20 bg-indigo-500 rounded"></div>
            </div>
            <p class="lg:w-1/2 w-full leading-relaxed text-gray-500">Discover the latest in web technology and
                development careers on my blog. From cutting-edge frameworks to career tips, navigate the digital
                landscape with insightful, concise posts</p>
        </div>
        <div class="flex flex-wrap -m-4">
            {% for post in collections.featured %}
            <a class="xl:w-1/4 md:w-1/2 p-4" href="{{post.url}}">
                <div class="h-full shadow-xl">
                    <picture>
                        <source type="image/webp" srcset="{{ post.data.featuredImg.url | webp | url }}">
                        <img class="bg-gray-100 h-40 rounded w-full object-cover object-center"
                            src="{{ '/assets/img/' | append: post.data.featuredImg.url | url }}"
                            width="{{post.data.featuredImg.width}}" height="{{post.data.featuredImg.height}}"
                            alt="{{ post.data.title }}" loading="lazy" />
                    </picture>
                    <div class="p-6">
                        <h3 class="text-lg text-gray-900 font-medium title-font mb-4">{{ post.data.title }}</h3>
                        <p class="leading-relaxed text-base">{{ post.data.description }}</p>
                    </div>
                </div>
            </a>
            {% endfor %}
        </div>
    </div>
</section>

<section class="text-gray-600 body-font">
    <div class="container px-5 py-8 md:py-24 mx-auto">
        <div class="flex flex-wrap w-full mb-20">
            <div class="lg:w-1/2 w-full mb-6 lg:mb-0">
                <h2 class="sm:text-3xl text-2xl font-medium title-font mb-2 text-gray-900">Collectives</h2>
                <div class="h-1 w-20 bg-indigo-500 rounded"></div>
            </div>
            <p class="lg:w-1/2 w-full leading-relaxed text-gray-500">Discover the latest in web technology and
                development careers on my blog. From cutting-edge frameworks to career tips, navigate the digital
                landscape with insightful, concise posts</p>
        </div>
        <div class="grid grid-cols-4 gap-8 -m-4">
            {% for post in collections.collectives %}
            <a href="{{post.url}}">
                <picture>
                    <source type="image/webp" srcset="{{ post.data.featuredImg.url | webp | url }}">
                    <img class="shadow-xl" src="{{ '/assets/img/' | append: post.data.featuredImg.url | url }}"
                        width="{{post.data.featuredImg.width}}" height="{{post.data.featuredImg.height}}"
                        alt="{{ post.data.title }}" loading="lazy" />
                </picture>
            </a>
            {% endfor %}
        </div>
    </div>
</section>